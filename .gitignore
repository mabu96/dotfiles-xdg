# Generated state and caches — never commit.
state/
cache/

# GPG private keys, entropy, locks — must never be committed.
config/gnupg/private-keys-v1.d/
config/gnupg/openpgp-revocs.d/
config/gnupg/random_seed
config/gnupg/trustdb.gpg
config/gnupg/pubring.kbx.lock
config/gnupg/.gpg-agent*

# AI agent credentials and session tokens — defensive defaults.
# Add per-tool excludes here as each tool reveals what it writes.
config/*/credentials*
config/*/.credentials*
config/*/auth*
config/*/.auth*
config/*/sessions/
config/*/*.token
config/*/*.key

# gh CLI: hosts.yml contains the auth token. config.yml has preferences (commit-safe).
config/gh/hosts.yml

# Raycast: extensions/ is regenerated on launch and can be hundreds of MB.
# Keep config.json (preferences) tracked, exclude the rest.
config/raycast/extensions/

# Ollama: model blobs are gigabytes; never commit. .ollama/manifest is tiny so
# allow tool-managed metadata, but exclude the heavy data dirs.
home/.ollama/models/
home/.ollama/blobs/
home/.ollama/history

# Defensive: anything in data/ matching 'private*'.
data/**/private*

# macOS Finder noise.
.DS_Store
