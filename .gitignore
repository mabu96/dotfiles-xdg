# Generated state and caches — never commit.
state/
cache/

# GPG private keys, entropy, locks — must never be committed.
config/gnupg/private-keys-v1.d/
config/gnupg/openpgp-revocs.d/
config/gnupg/random_seed
config/gnupg/trustdb.gpg
config/gnupg/pubring.kbx.lock
config/gnupg/.gpg-agent*

# AI agent credentials and session tokens — defensive defaults.
# Add per-tool excludes here as each tool reveals what it writes.
config/*/credentials*
config/*/.credentials*
config/*/auth*
config/*/.auth*
config/*/sessions/
config/*/*.token
config/*/*.key

# gh CLI: hosts.yml contains the auth token. config.yml has preferences (commit-safe).
config/gh/hosts.yml

# Raycast: extensions/ is regenerated on launch and can be hundreds of MB.
# Keep config.json (preferences) tracked, exclude the rest.
config/raycast/extensions/

# Ollama: model blobs are gigabytes; never commit. id_ed25519 is the local
# identity Ollama uses to authenticate to ollama.com — keep machine-local.
# logs/ is regenerable. config.json (preferences) is fine to track.
home/.ollama/models/
home/.ollama/blobs/
home/.ollama/history
home/.ollama/id_ed25519
home/.ollama/id_ed25519.pub
home/.ollama/logs/

# zsh: history and per-session state are machine-/account-local. Track
# .zprofile/.zshrc/.zlogin (your config) but exclude generated state.
# The shim symlink config/zsh/.zshenv → ~/.zshenv resolves to an
# account-specific absolute path and must not be committed.
config/zsh/.zsh_history
config/zsh/.zsh_sessions/
config/zsh/.zshenv

# npm global install root (NPM_CONFIG_PREFIX = $XDG_DATA_HOME/npm). Holds
# bin/ symlinks and lib/node_modules/ — installed packages, regeneratable.
data/npm/

# Defensive: anything in data/ matching 'private*'.
data/**/private*

# macOS Finder noise.
.DS_Store
